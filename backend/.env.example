FOUNDRY_ENVIRONMENT=development
FOUNDRY_DATA_DIR=.data
FOUNDRY_DATABASE_URL=postgresql+psycopg://foundry:foundry@localhost:5432/foundry
FOUNDRY_VECTOR_STORE_PROVIDER=chroma
FOUNDRY_VECTOR_DATABASE_URL=postgresql+psycopg://foundry:foundry@localhost:5432/foundry
FOUNDRY_VECTOR_COLLECTION_NAME=foundry_documents
FOUNDRY_CHROMA_PERSIST_DIR=.data/chroma
FOUNDRY_CHROMA_COLLECTION_NAME=healthcare_pdf_papers
FOUNDRY_EMBEDDING_PROVIDER=huggingface
FOUNDRY_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
FOUNDRY_HUGGINGFACE_EMBEDDING_MODEL=BAAI/bge-m3
# Alias also supported: EMBEDDING_MODEL_NAME=BAAI/bge-m3
FOUNDRY_PDF_PARSER=docling
FOUNDRY_REBUILD_INDEX_ON_STARTUP=true
FOUNDRY_DOCLING_CHUNKER_MAX_TOKENS=512
FOUNDRY_DOCLING_CHUNKER_MERGE_PEERS=true
FOUNDRY_SOURCE_PAPER_DIR=source/papers
FOUNDRY_RAG_ENABLED=true
FOUNDRY_RAG_TOP_K=10
FOUNDRY_FINAL_CONTEXT_TOP_K=5
FOUNDRY_RAG_SCORE_THRESHOLD=0.35
FOUNDRY_RAG_CHUNK_SIZE=1000
FOUNDRY_RAG_CHUNK_OVERLAP=150
FOUNDRY_BM25_INDEX_DIR=.data/bm25
FOUNDRY_KIWI_ENABLED=true
FOUNDRY_RRF_K=60
FOUNDRY_RERANKER_ENABLED=true
FOUNDRY_RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
# Keep false for lightweight local dev. Set true only when the model can be downloaded/loaded.
FOUNDRY_RERANKER_LOAD_MODEL=false
FOUNDRY_RERANK_TOP_N=10
FOUNDRY_RERANK_SCORE_THRESHOLD=0.2
FOUNDRY_MIN_CONTEXT_COUNT=2
FOUNDRY_WEB_SEARCH_PROVIDER=duckduckgo
FOUNDRY_WEB_FALLBACK_ENABLED=true
FOUNDRY_WEB_FALLBACK_PROVIDER=duckduckgo
FOUNDRY_WEB_FALLBACK_ON_EMPTY_CONTEXT=true
FOUNDRY_DUCKDUCKGO_MAX_RESULTS=5
FOUNDRY_TAVILY_API_KEY=
FOUNDRY_RAGAS_RESULTS_DIR=.data/evaluations
FOUNDRY_LANGGRAPH_TRACE_ENABLED=false
FOUNDRY_OPENAI_CHAT_MODEL=gpt-4o-mini
FOUNDRY_OLLAMA_BASE_URL=http://localhost:11434
FOUNDRY_OLLAMA_CHAT_MODEL=llama3.1
# Optional provider key used by bootstrap and OpenAI chat.
FOUNDRY_OPENAI_API_KEY=
# Optional dedicated key for embeddings. If empty, the app falls back to
# FOUNDRY_OPENAI_ADMIN_API_KEY, then OPENAI_API_KEY.
FOUNDRY_OPENAI_EMBEDDING_API_KEY=
OPENAI_API_KEY=
FOUNDRY_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:4173","http://127.0.0.1:4173"]
# Production/GCE: /etc/foundry/secrets/master.key
FOUNDRY_MASTER_KEY_PATH=.data/master.key
FOUNDRY_FAKE_LLM_ENABLED=false
FOUNDRY_FALLBACK_TO_LOCAL_MODEL_ON_PROVIDER_QUOTA=false
# Internal per-chat-session budget used by /status. This is not provider account quota.
FOUNDRY_CHAT_SESSION_TOKEN_BUDGET=100000
# Optional Admin API keys used only by /status provider quota lookup.
# These are separate from normal inference keys registered through /providers.
FOUNDRY_OPENAI_ADMIN_API_KEY=
FOUNDRY_ANTHROPIC_ADMIN_API_KEY=

POSTGRES_DB=foundry
POSTGRES_USER=foundry
POSTGRES_PASSWORD=foundry
