FOUNDRY_ENVIRONMENT=development
FOUNDRY_DATA_DIR=.data
FOUNDRY_DATABASE_URL=sqlite+aiosqlite:///./.data/foundry.db
FOUNDRY_CORS_ORIGINS=["http://localhost:3000","http://localhost:4173"]
# Production/GCE: /etc/foundry/secrets/master.key
FOUNDRY_MASTER_KEY_PATH=.data/master.key
# Local-only deterministic model. Set false when testing real OpenAI/Anthropic calls.
FOUNDRY_FAKE_LLM_ENABLED=true
# Internal per-chat-session budget used by /status. This is not provider account quota.
FOUNDRY_CHAT_SESSION_TOKEN_BUDGET=100000
# Optional Admin API keys used only by /status provider quota lookup.
# These are separate from normal inference keys registered through /providers.
FOUNDRY_OPENAI_ADMIN_API_KEY=
FOUNDRY_ANTHROPIC_ADMIN_API_KEY=
